   "source": [
    "numbers_str = input();\n",
    "\n",
    "numbers = numbers_str.split();\n",
    "\n",
    "x = int(numbers[0]);\n",
    "y = int(numbers[1]);\n",
    "z = int(numbers[2]);\n",
    "\n",
    "min = x; max = x;\n",
    "\n",
    "# min\n",
    "if y < min:\n",
    "    min = y;\n",
    "\n",
    "if z < min:\n",
    "    min = z;\n",
    "\n",
    "# max\n",
    "if y > max:\n",
    "    max = y;\n",
    "\n",
    "if z > max:\n",
    "    max = z;\n",
    "\n",
    "print(min, max);"
   ]
  }
