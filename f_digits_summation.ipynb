    "\n",
    "numbers = inp.split();\n",
    "\n",
    "x = int(numbers[0]);\n",
    "y = int(numbers[1]);\n",
    "\n",
    "last_digit_of_x = x % 10;\n",
    "last_digit_of_y = y % 10;\n",
    "\n",
    "sum = last_digit_of_x + last_digit_of_y;\n",
    "\n",
    "print(sum)"
