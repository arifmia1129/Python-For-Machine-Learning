   "source": [
    "tc = int(input());\n",
    "\n",
    "for i in range(tc):\n",
    "    n = int(input());\n",
    "\n",
    "    if n == 0:\n",
    "        print(0);\n",
    "        continue;\n",
    "    \n",
    "    while n > 0:\n",
    "        print(n % 10, end=\" \");\n",
    "        n //= 10;\n",
    "    print();"
   ]
  }
